[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/overlays/pause_overlay.gd" id="1"]
[ext_resource type="FontFile" path="res://assets/fonts/Orbitron-Bold.ttf" id="2"]

[node name="PauseOverlay" type="CanvasLayer"]
layer = 20
process_mode = 3
script = ExtResource("1")

[node name="Dim" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 0
color = Color(0.01, 0.005, 0.04, 0.75)

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -180.0
offset_right = 200.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 0

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2
theme_override_constants/separation = 24
alignment = 1

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 1, 1, 1)
theme_override_fonts/font = ExtResource("2")
theme_override_font_sizes/font_size = 36
text = "PAUSED"
horizontal_alignment = 1

[node name="Sep" type="HSeparator" parent="Panel/VBox"]
layout_mode = 2
modulate = Color(0, 1, 1, 0.3)

[node name="ResumeBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(280, 64)
theme_override_fonts/font = ExtResource("2")
theme_override_font_sizes/font_size = 26
text = "RESUME"

[node name="MenuBtn" type="Button" parent="Panel/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(280, 58)
theme_override_fonts/font = ExtResource("2")
theme_override_font_sizes/font_size = 22
text = "MENU"

[connection signal="pressed" from="Panel/VBox/ResumeBtn" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="Panel/VBox/MenuBtn" to="." method="_on_menu_pressed"]

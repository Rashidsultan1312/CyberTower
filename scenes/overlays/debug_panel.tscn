[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/overlays/debug_panel.gd" id="1"]

[node name="DebugPanel" type="CanvasLayer"]
layer = 90
process_mode = 3
script = ExtResource("1")

[node name="ToggleBtn" type="Button" parent="."]
anchors_preset = 0
offset_left = 10.0
offset_top = 10.0
offset_right = 80.0
offset_bottom = 40.0
modulate = Color(1, 1, 1, 0.4)
theme_override_font_sizes/font_size = 12
text = "DEBUG"

[node name="Panel" type="PanelContainer" parent="."]
visible = false
anchors_preset = 0
offset_left = 10.0
offset_top = 50.0
offset_right = 350.0
offset_bottom = 600.0
mouse_filter = 0

[node name="Scroll" type="ScrollContainer" parent="Panel"]
layout_mode = 2

[node name="VBox" type="VBoxContainer" parent="Panel/Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="TitleLabel" type="Label" parent="Panel/Scroll/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 1, 1, 1)
theme_override_font_sizes/font_size = 20
text = "DEBUG PANEL"

[node name="FPSLabel" type="Label" parent="Panel/Scroll/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 1, 0.7, 1)
theme_override_font_sizes/font_size = 16
text = "FPS: 0"

[node name="GodRow" type="HBoxContainer" parent="Panel/Scroll/VBox"]
layout_mode = 2

[node name="GodLabel" type="Label" parent="Panel/Scroll/VBox/GodRow"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 16
text = "GOD MODE"

[node name="GodCheck" type="CheckButton" parent="Panel/Scroll/VBox/GodRow"]
layout_mode = 2

[node name="AddCoinsBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "+100 COINS"

[node name="UnlockAllBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "UNLOCK ALL SKINS"

[node name="CompletePuzzlesBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "COMPLETE PUZZLES"

[node name="AddCrystalsBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "+10 CRYSTALS"

[node name="AddPowerupsBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "ADD ALL POWERUPS"

[node name="ResetMissionsBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "RESET MISSIONS"

[node name="ResetAchBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "RESET ACHIEVEMENTS"

[node name="ResetSaveBtn" type="Button" parent="Panel/Scroll/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
text = "RESET SAVE"

[connection signal="pressed" from="ToggleBtn" to="." method="_on_toggle_pressed"]
[connection signal="toggled" from="Panel/Scroll/VBox/GodRow/GodCheck" to="." method="_on_god_toggled"]
[connection signal="pressed" from="Panel/Scroll/VBox/AddCoinsBtn" to="." method="_on_add_coins_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/UnlockAllBtn" to="." method="_on_unlock_all_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/CompletePuzzlesBtn" to="." method="_on_complete_puzzles_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/AddCrystalsBtn" to="." method="_on_add_crystals_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/AddPowerupsBtn" to="." method="_on_add_powerups_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/ResetMissionsBtn" to="." method="_on_reset_missions_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/ResetAchBtn" to="." method="_on_reset_ach_pressed"]
[connection signal="pressed" from="Panel/Scroll/VBox/ResetSaveBtn" to="." method="_on_reset_save_pressed"]
